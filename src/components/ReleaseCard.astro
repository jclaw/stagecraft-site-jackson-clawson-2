---
import type { Release } from "../lib/schemas";
import Button from "./Button.astro";
import { Image } from "astro:assets";

interface Props {
  release: Release;
}

const { release } = Astro.props;
const streamLinks = Object.entries(release.links).filter(([, url]) => url);
---

<article class="release-card">
  {release.coverImage && (
    <div class="release-cover">
      <Image src={release.coverImage.src} alt={release.coverImage.alt} width={500} height={500} />
    </div>
  )}
  <div class="release-info">
    <h3>{release.title}</h3>
    <p class="release-meta">
      <span class="release-type">{release.type}</span>
      <span class="release-date">{release.releaseDate}</span>
    </p>
    <p class="release-desc">{release.description}</p>
    {streamLinks.length > 0 && (
      <div class="release-links">
        {streamLinks.map(([platform, url]) => (
          <Button href={url} variant="outline" isExternal class="release-link-btn">
            {platform}
          </Button>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .release-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .release-cover {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .release-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .release-info {
    padding: 1.5rem;
  }

  .release-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .release-type {
    text-transform: uppercase;
    font-weight: var(--font-weight-semibold);
    color: var(--color-secondary);
  }

  .release-desc {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
  }

  .release-links {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .release-link-btn {
    font-size: var(--font-size-xs);
    padding: 0.5rem 1rem;
    text-transform: capitalize;
  }
</style>
